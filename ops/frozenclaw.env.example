NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

NEXT_PUBLIC_URL=http://46.225.143.215
APP_BASE_URL=http://46.225.143.215
DATA_DIR=/opt/frozenclaw/data

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PROVISIONING_MODE=script
PROVISIONING_USE_SUDO=true
PROVISIONING_SCRIPT=/opt/frozenclaw/app/scripts/server/provision-instance.sh
RESTART_INSTANCE_SCRIPT=/opt/frozenclaw/app/scripts/server/restart-instance.sh
DEPROVISION_SCRIPT=/opt/frozenclaw/app/scripts/server/deprovision-instance.sh
PROVISIONING_PORT_START=45000
PROVISIONING_PORT_END=45999
PROVISIONING_STALE_MINUTES=5
AGENT_BASE_PATH=/agent
SETUP_BASE_PATH=/zugang
CUSTOMER_ROOT_DIR=/opt/frozenclaw/customers
APP_SYSTEM_USER=frozenclaw
APP_SYSTEM_GROUP=frozenclaw
OPENCLAW_IMAGE=frozenclaw/openclaw:latest
OPENCLAW_REPO_DIR=/opt/frozenclaw/vendor/openclaw
OPENCLAW_GIT_REF=v2026.3.13-1
SERVER_TIMEZONE=Europe/Berlin
